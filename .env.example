# MarinerX Quant Command Center — environment template
# Copy to .env for local development. Never commit real secrets.

APP_ENV=local
APP_HOST=0.0.0.0
APP_PORT=8000
SERVICE_MODE=web

PUBLIC_FRONTEND_URL=http://localhost:8000
BACKEND_PUBLIC_URL=http://localhost:8000
WEBSOCKET_PUBLIC_URL=ws://localhost:8000/ws

# Local SQLite (default when DATABASE_URL unset)
# DATABASE_URL=postgresql://user:pass@host:5432/mcc

DATA_DIR=./data
LOG_DIR=./data/logs
PARQUET_DIR=./data/parquet
REPORTS_DIR=./data/reports
LOCAL_OBJECT_STORAGE_DIR=./data/objects

OBJECT_STORAGE_BACKEND=local

# Cloudflare R2 (required when OBJECT_STORAGE_BACKEND=r2 in production)
# R2_ACCOUNT_ID=
# R2_ACCESS_KEY_ID=
# R2_SECRET_ACCESS_KEY=
# R2_BUCKET_NAME=
# R2_PUBLIC_BASE_URL=

ENABLE_LIVE_EXECUTION=false
CORS_ALLOWED_ORIGINS=*

STRUCTLOG_LEVEL=INFO
AGENT_HEARTBEAT_INTERVAL_SECONDS=30
WORKER_SHUTDOWN_TIMEOUT_SECONDS=30
HEALTHCHECK_TIMEOUT_SECONDS=5

APP_VERSION=0.1.0

# Tradeify 150K Select Flex data connectors
MARINERX_TRADEIFY_MODE=PAPER_FIRST
MARINERX_TRADEIFY_DATA_ENABLED=true
MARINERX_TRADEIFY_DASHBOARD_ENABLED=false
MARINERX_TRADOVATE_ENABLED=true
MARINERX_ALLOW_LIVE_ORDERS=false
MARINERX_TRADEIFY_MAX_FRESH_SECONDS=60
MARINERX_TRADEIFY_STALE_BLOCK_SECONDS=180
MARINERX_TRADEIFY_RECONCILIATION_TOLERANCE=25
MARINERX_TRADOVATE_ENVIRONMENT=demo

# Tradovate API (set in Render secrets / local .env — never commit)
# TRADOVATE_CID=
# TRADOVATE_SECRET=
# TRADOVATE_USERNAME=
# TRADOVATE_PASSWORD=
# TRADOVATE_APP_ID=
# TRADOVATE_APP_VERSION=
# TRADOVATE_DEVICE_ID=
# TRADOVATE_ACCOUNT_ID=

# Tradeify dashboard Playwright session (local only)
# TRADEIFY_DASHBOARD_URL=https://app.tradeify.co
# TRADEIFY_DASHBOARD_STORAGE_STATE=./data/secure/tradeify_storage_state.json